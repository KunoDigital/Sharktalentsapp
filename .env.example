# ==========================================================================
# SharkTalents — env vars template
# Copiá a .env.local para desarrollo. NO comitees .env con valores reales.
# Para producción se setean en Catalyst Console → Functions → api → Env Vars.
# ==========================================================================

# --- BACKEND (function `api`) ---

# Auth (Clerk) — ver docs/master-plan/14_CLERK_AUTH.md
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-replace-me

# Internal / infra (generar con scripts/generate-secret.sh)
INTERNAL_API_KEY=replace-with-64-hex-chars
URL_SIGNING_SECRET=replace-with-64-hex-chars
CRYPTO_MASTER_KEY=replace-with-64-hex-chars

# URLs (ajustar por ambiente)
APP_BASE_URL=https://sharktalents.ai
CLIENT_HOSTING_BASE=/app/index.html
PUBLIC_REPORT_BASE=/app/index.html#/report
TEST_LINK_BASE=/app/index.html#/test

# Anthropic config
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_CACHING_ENABLED=true
ANTHROPIC_TIMEOUT_MS=25000
ANTHROPIC_MAX_RETRIES=3

# Reliability
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=60000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# API pública
API_V1_RATE_LIMIT_DEFAULT=60
API_V1_RATE_LIMIT_PER_TENANT=1000

# Logging
LOG_LEVEL=info
APP_VERSION=0.1.0

# --- Zoho (Recruit / Meeting / Zia / Bookings / Sign) — ver doc 23 ---
ZOHO_DC=com
ZOHO_CLIENT_ID=1000.xxxxx
ZOHO_CLIENT_SECRET=xxxxx
ZOHO_RECRUIT_WEBHOOK_TOKEN=replace-with-32-hex-chars
ZOHO_MEETING_WEBHOOK_SECRET=replace-with-32-hex-chars
ZOHO_BOOKINGS_WEBHOOK_TOKEN=replace-with-32-hex-chars
ZOHO_SIGN_WEBHOOK_SECRET=replace-with-32-hex-chars

# --- OpenAI Whisper (fallback transcripción — docs 20, 23) ---
OPENAI_API_KEY=sk-xxxxx
WHISPER_FALLBACK_ENABLED=true
WHISPER_LANGUAGE_DEFAULT=es

# --- HeyReach (outbound LinkedIn — doc 22) ---
HEYREACH_API_KEY=hr_xxxxx
HEYREACH_LINKEDIN_ACCOUNT_ID=xxxxx
HEYREACH_WEBHOOK_SECRET=replace-with-32-hex-chars
HEYREACH_DAILY_INVITE_LIMIT=5

# --- WhatsApp (notificaciones cliente — doc 17) ---
WHATSAPP_PROVIDER=twilio
WHATSAPP_API_KEY=xxxxx
WHATSAPP_FROM_NUMBER=+507xxxxx

# --- Bot decisor (doc 21) ---
BOT_MODE=cold
BOT_CONFIDENCE_THRESHOLD_DEFAULT=0.75
BOT_RAG_TOP_K=5

# ==========================================================================
# --- FRONTEND ---
# El frontend lee desde shark/.env.development y shark/.env.production.
# Ver shark/.env.example para la lista completa.
# Recordatorio: TODAS las VITE_* van al bundle visible. NUNCA secrets.
# ==========================================================================
