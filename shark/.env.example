# ==========================================================================
# Frontend env vars (Vite — prefix VITE_ es obligatorio)
# ⚠️ Recordatorio: TODAS las VITE_* van al bundle visible. NUNCA secrets.
# Copiá a .env.development (dev) o .env.production (build prod).
# ==========================================================================

# URL del backend API
VITE_API_BASE=http://localhost:3002/api

# Versión visible en UI
VITE_APP_VERSION=0.1.0

# URL pública de la app (para armar links compartibles)
VITE_APP_BASE_URL=http://localhost:3000

# Path del client hosting bajo el dominio
VITE_CLIENT_HOSTING_PATH=/

# Clerk (publishable key — ok público)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
